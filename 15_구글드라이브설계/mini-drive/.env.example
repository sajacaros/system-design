# Mini Drive — 환경변수 템플릿 (.env.example)
# 사용법: 이 파일을 `.env`로 복사한 뒤 실제 값(특히 시크릿)을 교체한다.
#   cp .env.example .env
# 주의: 실제 .env(시크릿 포함)는 절대 커밋하지 않는다. 아래는 모두 예시값.

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=minidrive
POSTGRES_USER=minidrive
POSTGRES_PASSWORD=change-me-postgres-password   # 예시: 운영에서 강한 비밀번호로 교체
POSTGRES_PORT=5432

# ── MinIO (S3 호환 스토리지) ──────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password     # 예시: 8자 이상 강한 비밀번호로 교체
MINIO_BUCKET=minidrive
MINIO_REGION=us-east-1
MINIO_CONSOLE_PORT=9001
# ── 계약 v1.6 폐기 항목 (게이트웨이 경유 다운로드, X-Accel-Redirect) ──
# MINIO_API_PORT: 폐기. S3 데이터 평면(9000)은 더 이상 호스트로 published 하지 않는다.
#   docker-compose 에서 `expose: ["9000"]`(도커 네트워크 내부 전용)로 전환됨.
#   다운로드는 nginx /_minio/ internal location 만 MinIO 에 접근한다.
# MINIO_PUBLIC_ENDPOINT: 폐기. 브라우저-facing presigned URL 제거로 공개 호스트 불요.
#   백엔드가 더 이상 읽지 않음(내부 presign 은 호스트/스킴 무관, nginx 가 경로+쿼리만 사용).

# ── JWT ───────────────────────────────────────────────────────
# 예시값. 운영에서는 256-bit 이상 랜덤 시크릿으로 교체할 것.
#   생성 예: openssl rand -base64 48
JWT_SECRET=change-me-please-use-a-long-random-secret-string-256bit
JWT_ACCESS_TTL_SECONDS=900          # Access 토큰 15분
JWT_REFRESH_TTL_SECONDS=1209600     # Refresh 토큰 14일

# ── 포트 / 프로필 ─────────────────────────────────────────────
HTTP_PORT=7915                      # Nginx 리버스 프록시 외부 포트
BACKEND_PORT=18080                  # 백엔드 직접 접근(디버그용)
SPRING_PROFILES_ACTIVE=docker
