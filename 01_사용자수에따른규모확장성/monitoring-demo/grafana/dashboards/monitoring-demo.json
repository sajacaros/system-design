  "panels": [
    {
      "type": "timeseries",
      "title": "Process CPU Usage (%)",
      "description": "현재 JVM 프로세스가 사용하는 CPU 비율 (1.0 = 코어 1개 100%)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "process_cpu_usage{application=\"monitoring-demo\"}",
          "legendFormat": "process",
          "refId": "A"
        },
        {
          "expr": "system_cpu_usage{application=\"monitoring-demo\"}",
          "legendFormat": "system",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM Heap Memory (MB)",
      "description": "JVM 힙 메모리 사용량 / 커밋된 용량",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{application=\"monitoring-demo\",area=\"heap\"}) / 1024 / 1024",
          "legendFormat": "heap used",
          "refId": "A"
        },
        {
          "expr": "sum(jvm_memory_committed_bytes{application=\"monitoring-demo\",area=\"heap\"}) / 1024 / 1024",
          "legendFormat": "heap committed",
          "refId": "B"
        },
        {
          "expr": "sum(jvm_memory_max_bytes{application=\"monitoring-demo\",area=\"heap\"}) / 1024 / 1024",
          "legendFormat": "heap max",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM Threads",
      "description": "현재 살아있는 스레드 수",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"monitoring-demo\"}",
          "legendFormat": "live",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Request Rate (req/s)",
      "description": "초당 HTTP 요청 처리량 (1분 이동 평균)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count{application=\"monitoring-demo\"}[1m]))",
          "legendFormat": "{{uri}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Latency p95 (s)",
      "description": "HTTP 응답 시간 95퍼센타일 (1분 윈도우)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (uri, le) (rate(http_server_requests_seconds_bucket{application=\"monitoring-demo\"}[1m])))",
          "legendFormat": "{{uri}}",
          "refId": "A"
        }
      ]
    }
  ],
